  "id": "sms-demo-app",
  "info": {
    "keywords": ["app"],
    "description": "",
    "author": {
      "name": "Sms"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Home",
